# No API key required — this agent uses the Claude Agent SDK which
# authenticates via your Claude Code CLI login (your Claude subscription).
#
# Prerequisites:
#   1. Install Claude Code CLI and run `claude login` once.
#   2. pip install -r requirements.txt
#
# The agent also loads MVP-Access-API-Test/.env for SMTP / TEAM_EMAILS.

# ─── Daily Report email identity + recipients ───────────────────────────
# The consolidated daily report is the ONLY email the team receives per
# day. Sender renders as "NAPCO Nucleus <khasan@ael-bd.com>".
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=khasan@ael-bd.com
# SMTP_PASSWORD=
# SMTP_FROM=khasan@ael-bd.com
# SMTP_FROM_NAME=NAPCO Nucleus
# TEAM_EMAILS=arzaman@ael-bd.com,titucse@gmail.com,assad@ael-bd.com,samin@ael-bd.com
# REPORT_TO=arzaman@ael-bd.com,titucse@gmail.com,assad@ael-bd.com,samin@ael-bd.com

# ─── Optional path overrides ─────────────────────────────────────────────
# Where the four MVP-Access-* projects live. Defaults to the parent folder
# of THIS project (sibling layout). Set this only if your projects live
# somewhere else.
# MVP_PROJECTS_ROOT=E:\Projects

# Path to the logged-in Claude Code CLI binary. Defaults to:
#   %USERPROFILE%\.local\bin\claude.exe
# CLAUDE_CLI_PATH=C:\path\to\claude.exe

# Optional Microsoft Teams incoming webhook URL. When set, the agent posts
# a short MessageCard digest after each run. Leave unset to disable.
# Create one in Teams: channel → Connectors → Incoming Webhook → Configure.
# TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...

# ─── Requirement Management dimension ────────────────────────────────────
# The agent polls an IMAP mailbox, keeps only messages from senders on the
# allowlist, and saves each as a .txt under data/requirements/inbox/email/.
# Meeting transcripts go under data/requirements/inbox/meetings/ (drop
# exported .txt files there yourself). The agent then LLM-splits every
# inbox file into ~3-hour tasks and opens them as GitLab issues.
#
# REQ_IMAP_HOST=imap.gmail.com
# REQ_IMAP_PORT=993
# REQ_IMAP_USER=you@example.com
# REQ_IMAP_PASSWORD=
# Comma-separated sender addresses — every email from these is a requirement.
# REQ_SENDER_ALLOWLIST=client-a@acme.com,client-b@acme.com
#
# GitLab target — gitlab.com project where the backlog lives. PAT needs
# `api` scope. Create at gitlab.com → User Settings → Access Tokens.
# GITLAB_HOST=https://gitlab.com
# GITLAB_PROJECT_ID=
# GITLAB_TOKEN=
# Labels applied to every new issue (comma-separated, optional).
# GITLAB_DEFAULT_LABELS=requirement,backlog
