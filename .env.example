# NAPCO Nucleus — local environment.
# Copy this file to .env and fill in your own credentials.
# Single source of truth for every secret NN reads.
# Do not commit .env — it is in .gitignore.

# ─── Claude Agent SDK ────────────────────────────────────────────────
# No API key needed — the SDK uses the locally-logged-in Claude CLI.
CLAUDE_CLI_PATH=%USERPROFILE%\.local\bin\claude.exe

# ─── Daily Report email identity + recipients ───────────────────────
# Sender renders as "NAPCO Nucleus <khasan@ael-bd.com>".
# For Gmail, SMTP_PASSWORD must be a 16-character App Password
# (Google Account → Security → 2-Step Verification → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=khasan@ael-bd.com
SMTP_PASSWORD=
SMTP_FROM=khasan@ael-bd.com
SMTP_FROM_NAME=NAPCO Nucleus
# Detailed daily report goes to the full team
TEAM_EMAILS=khasan@ael-bd.com,assad@ael-bd.com,arzaman@ael-bd.com,samin@ael-bd.com,ihasan@ael-bd.com,titucse@gmail.com
REPORT_TO=khasan@ael-bd.com,assad@ael-bd.com,arzaman@ael-bd.com,samin@ael-bd.com,ihasan@ael-bd.com,titucse@gmail.com

# Executive summary report goes to leadership only (will grow over time)
SUMMARY_EMAILS=khasan@ael-bd.com,assad@ael-bd.com

# ─── Requirement Management — IMAP poll ──────────────────────────────
# TODO: paste from GHA secrets store (REQ_IMAP_USER, REQ_IMAP_PASSWORD,
# REQ_SENDER_ALLOWLIST). The mailbox is typically khasan@ael-bd.com or
# a dedicated requirements mailbox. App password recommended for Gmail.
REQ_IMAP_HOST=imap.gmail.com
REQ_IMAP_PORT=993
REQ_IMAP_USER=khasan@ael-bd.com
REQ_IMAP_PASSWORD=
REQ_SENDER_ALLOWLIST=titucse@gmail.com,khasan@ael-bd.com

# ─── Requirement Management — OpenProject backlog ──────────────────
# Replaces the prior GitLab integration (2026-04-28). The API key is a
# personal-access token from My account → Access tokens. HTTP Basic
# auth: username 'apikey', password is the token.
OPENPROJECT_URL=https://napco.openproject.com
OPENPROJECT_PROJECT_ID=mvp-access
OPENPROJECT_API_KEY=

# ─── Requirement Management — Google Drive ingest ───────────────────
# TODO: drop the service-account JSON as ./google-credentials.json
# (DD already has one at E:/Personal/Digital-Deputy/google-credentials.json
#  — verify it has Viewer on NN's Drive folder before reusing).
# TODO: paste GDRIVE_AUDIO_FOLDER_ID from GHA secrets store.
GOOGLE_CREDENTIALS_PATH=google-credentials.json
GDRIVE_AUDIO_FOLDER_ID=1u7Y2I17VKRnyoBRTY97_W81Lt7Hp5PK3

# ─── Requirement Management — Groq Whisper transcription ────────────
# TODO: paste GROQ_API_KEY from GHA secrets store. Required only if
# the Drive folder will contain audio/video.
GROQ_API_KEY=

# ─── Microsoft Teams digest (optional) ──────────────────────────────
# TODO: paste TEAMS_WEBHOOK_URL from GHA secrets store, or leave blank
# to disable Teams posting.
TEAMS_WEBHOOK_URL=

# ─── Path overrides ─────────────────────────────────────────────────
# Defaults to the parent of this project. Override only if your sibling
# test projects live somewhere other than E:\Projects.
# MVP_PROJECTS_ROOT=E:\Projects

# Teams chat — friendly-name aliases for python -m teams.pull_chat --name <name>
# Format: alias=identifier (chat number or 19:... conv_id), comma-separated.
CHAT_ALIASES=ContiHosting=123,Assad=123,Atikur=123,Isruk=123,Kamrul=123,Rocky=123,Mostafa=123,Salman=123

# Central capture (added 2026-05-08)
NUCLEUS_CENTRAL_PATH=\\172.16.205.209\nucleus-central
# Optional friendlier label for this dev's folder on central. Defaults
# to %USERNAME% if unset.
# NUCLEUS_DEV_NAME=

# Optional override for the chat-attachment resolver. Comma-separated
# list of dirs to scan for Teams-downloaded files. Defaults to
# ~/Downloads + any Teams subfolders.
# NUCLEUS_DOWNLOADS_PATH=
