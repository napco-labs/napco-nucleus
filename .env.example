# NAPCO Nucleus — environment variable contract.
# Copy to .env and fill in. Never commit .env itself.
#
# NN owns its own secrets (Digital-Deputy-style). Every var the agent
# reads is listed below; nothing else is required. The agent does NOT
# reach into sibling test-project .env files anymore.

# ─── Claude Agent SDK ────────────────────────────────────────────────
# No API key needed — the SDK authenticates via your Claude Code CLI
# login (your Claude Max subscription). Setting ANTHROPIC_API_KEY here
# would force the SDK onto API credits instead — leave it unset.
CLAUDE_CLI_PATH=%USERPROFILE%\.local\bin\claude.exe

# ─── Daily Report email identity + recipients ───────────────────────
# The consolidated daily report is the ONLY email the team receives
# per day. Sender renders as "NAPCO Nucleus <khasan@ael-bd.com>".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=khasan@ael-bd.com
SMTP_PASSWORD=
SMTP_FROM=khasan@ael-bd.com
SMTP_FROM_NAME=NAPCO Nucleus
# Comma-separated. While validating end-to-end, keep a single recipient.
TEAM_EMAILS=
REPORT_TO=

# ─── Requirement Management — IMAP poll ──────────────────────────────
# The agent polls this mailbox, keeps only messages from senders on the
# allowlist, and saves each one under data/requirements/inbox/email/.
REQ_IMAP_HOST=imap.gmail.com
REQ_IMAP_PORT=993
REQ_IMAP_USER=
REQ_IMAP_PASSWORD=
# Comma-separated sender addresses — every email from these is treated
# as a requirement.
REQ_SENDER_ALLOWLIST=

# ─── Requirement Management — GitLab backlog ────────────────────────
# Where the LLM-split tasks land. PAT needs `api` scope.
# Create at gitlab.com → User Settings → Access Tokens.
GITLAB_HOST=https://gitlab.com
GITLAB_PROJECT_ID=
GITLAB_TOKEN=
# Labels applied to every new issue (comma-separated, optional).
GITLAB_DEFAULT_LABELS=requirement,backlog

# ─── Requirement Management — Google Drive ingest ───────────────────
# The Drive folder holds meeting recordings (audio/video → Whisper)
# and PDF attachments (→ pypdf). The folder ID is the long string in
# the folder's URL. The service account must have at least Viewer.
#
# Authentication — pick ONE of these two:
#   1. GOOGLE_CREDENTIALS_PATH  → file path (preferred; DD-style).
#      Save the JSON key as google-credentials.json at the project
#      root and leave this line as-is. Relative paths resolve against
#      the project root.
#   2. GOOGLE_SERVICE_ACCOUNT_JSON → raw JSON blob (legacy, kept so
#      GitHub Actions secrets continue to work). Pasted as a single
#      line. If both are set, GOOGLE_CREDENTIALS_PATH wins.
GOOGLE_CREDENTIALS_PATH=google-credentials.json
# GOOGLE_SERVICE_ACCOUNT_JSON=
GDRIVE_AUDIO_FOLDER_ID=

# ─── Requirement Management — Groq Whisper transcription ────────────
# Used only when the Drive folder contains audio/video files.
GROQ_API_KEY=
# Optional. Defaults to whisper-large-v3-turbo.
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─── Microsoft Teams digest (optional) ──────────────────────────────
# When set, the agent posts a short MessageCard digest after each run.
# Create one in Teams: channel → Connectors → Incoming Webhook.
TEAMS_WEBHOOK_URL=

# ─── Path overrides (only set if your layout differs) ───────────────
# Where the four MVP-Access-* sibling test projects live. Defaults to
# the parent folder of THIS project (sibling layout).
# MVP_PROJECTS_ROOT=E:\Projects
