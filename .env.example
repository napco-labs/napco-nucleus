# No API key required — this agent uses the Claude Agent SDK which
# authenticates via your Claude Code CLI login (your Claude subscription).
#
# Prerequisites:
#   1. Install Claude Code CLI and run `claude login` once.
#   2. pip install -r requirements.txt
#
# The agent also loads MVP-Access-API-Test/.env for SMTP / TEAM_EMAILS.

# ─── Optional path overrides ─────────────────────────────────────────────
# Where the four MVP-Access-* projects live. Defaults to the parent folder
# of THIS project (sibling layout). Set this only if your projects live
# somewhere else.
# MVP_PROJECTS_ROOT=E:\Projects

# Path to the logged-in Claude Code CLI binary. Defaults to:
#   %USERPROFILE%\.local\bin\claude.exe
# CLAUDE_CLI_PATH=C:\path\to\claude.exe

# Optional Microsoft Teams incoming webhook URL. When set, the agent posts
# a short MessageCard digest after each run. Leave unset to disable.
# Create one in Teams: channel → Connectors → Incoming Webhook → Configure.
# TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...
