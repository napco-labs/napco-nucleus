# NAPCO Nucleus central -- Linux deploy environment template.
#
# Copy to .env on the host (172.16.205.123) and fill in the secrets:
#   cp .env.example .env
#   nano .env
# .env is gitignored. Never commit secrets to the repo.

# ----------------------------------------------------------------
# Samba share -- single shared user for all dev PCs.
# ----------------------------------------------------------------
SAMBA_USER=nucleus
SAMBA_PASSWORD=changeme-pick-a-strong-one

# ----------------------------------------------------------------
# Paths on the host. Defaults are fine for the standard layout.
# ----------------------------------------------------------------
REPO_PATH=/home/ubuntu/napco-nucleus
CLAUDE_HOME=/home/ubuntu/.claude
CLAUDE_JSON=/home/ubuntu/.claude.json

# ----------------------------------------------------------------
# Transcription. GROQ_API_KEY is the primary path; faster-whisper
# is the fallback (rarely invoked). Copy from the .209 .env.
# ----------------------------------------------------------------
GROQ_API_KEY=
GROQ_TEAMS_WHISPER_MODEL=whisper-large-v3

# ----------------------------------------------------------------
# Google APIs -- Gmail + Drive credentials. Copy from .209.
# The OAuth token files themselves are mounted via the repo, but
# any env-driven config (project IDs, scopes) goes here.
# ----------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=
NAPCO_GMAIL_ACCOUNT=

# ----------------------------------------------------------------
# Anthropic. If you DON'T use the Max-tier bind-mount path, set the
# API key here and remove the CLAUDE_HOME/CLAUDE_JSON volumes from
# docker-compose.yml.
# ----------------------------------------------------------------
# ANTHROPIC_API_KEY=

# ----------------------------------------------------------------
# Cadence overrides (seconds). Defaults match the .209 setup.
# ----------------------------------------------------------------
# TRANSCRIBE_INTERVAL_SECONDS=120
# STAGE_EMAIL_INTERVAL_SECONDS=900
# STAGE_DRIVE_INTERVAL_SECONDS=900
# DAILY_DRAFT_TARGET_TIME=23:45
# DAILY_DRAFT_LOOKBACK_MINUTES=1440

# ----------------------------------------------------------------
# GitHub Actions runner -- org-scoped to napco-labs.
# GHA_RUNNER_TOKEN is the one-shot REGISTRATION TOKEN (not a PAT). Get
# one from the org's runners page in GitHub settings, or via API:
#   POST /orgs/napco-labs/actions/runners/registration-token
# Registration tokens expire ~1h after issuance; you only need it for
# the first `--profile runner` up. Once registered the runner persists.
# Only used when the stack is brought up with --profile runner.
# ----------------------------------------------------------------
GHA_RUNNER_ORG=napco-labs
GHA_RUNNER_TOKEN=
